generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  telegramId         BigInt   @unique
  username           String?
  firstName          String
  lastName           String?
  languageCode       String?
  photoUrl           String?
  progress           Json?
  visitCount         Int      @default(0)
  progressSaveCount  Int      @default(0)
  lastSeenAt         DateTime?
  lastProgressSaveAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
